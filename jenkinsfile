pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-lab:v1 .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run --rm devops-lab:v1'
            }
        }

        stage('List Images') {
            steps {
                sh 'docker images'
            }
        }
    }
}
